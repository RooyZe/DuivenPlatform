<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DuivenPlatform</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <div class="app-shell">

        <header class="site-header">
            <div class="header-inner">
                <div class="header-left">
                    <a href="@Url.Action("Index", "Home")" class="logo-link" aria-label="Combinatie ten Cate">
                        <img src="@(Url.Content("~/images/duif.jpg"))" alt="Combinatie ten Cate" class="logo-img" onerror="this.onerror=null;this.src='@(Url.Content("~/images/logo.svg"))'" />
                    </a>
                </div>

                <div class="header-title">
                    <a href="@Url.Action("Index", "Home")">Combinatie ten Cate</a>
                </div>

                <div class="header-icons">
                    <a href="@Url.Action("Cart", "Home")" title="Winkelwagen" class="icon spa-link">🛒</a>
                    <a href="#" title="User" class="icon">👤</a>
                    <a href="@Url.Action("Navigation", "Home")" class="icon spa-link" aria-label="Open navigatie">☰</a>
                </div>
            </div>
        </header>

        <main class="site-main">
            @RenderBody()
        </main>

    </div>

    <script src="~/js/site.js" asp-append-version="true"></script>
</body>
</html>