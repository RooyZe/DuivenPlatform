@model List<DuivenPlatform.Web.Models.PigeonDto>
@{
    ViewData["Title"] = "Duiven te koop";
}

<section class="home-page">
    <div class="section-bar">
        <h2>Duiven te koop</h2>
    </div>

    <div class="pigeons-grid">
        @if (Model != null && Model.Any())
        {
            foreach (var pigeon in Model)
            {
                <div class="pigeon-card">
                    <img src="@pigeon.ImageUrl" alt="@pigeon.Title" class="pigeon-image" />
                    <div class="pigeon-info">
                        <h3>@pigeon.Title</h3>
                        @if (!string.IsNullOrEmpty(pigeon.Description))
                        {
                            <p class="pigeon-description">@pigeon.Description</p>
                        }
                        <div class="pigeon-price">
                            Prijs: @pigeon.Price.ToString("C")
                        </div>
                        <div class="pigeon-actions">
                            <a href="#" class="btn btn-info">Meer informatie</a>
                            <a href="#" class="btn btn-success">Voeg toe!</a>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="info-card">
                <div class="info-card-inner">
                    <p>Geen duiven beschikbaar.</p>
                </div>
            </div>
        }
    </div>
</section>
